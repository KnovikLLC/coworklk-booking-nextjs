# App
NEXT_PUBLIC_URL=https://cowork.lk
NEXT_PUBLIC_PHONE=+94774884040

# Supabase
# For local dev: run `pnpm supabase start` and copy the printed API_URL / anon key / service_role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayHere
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=sandbox

# Zoho Books
# Leave blank in dev — Zoho integration is designed to degrade gracefully (no crashes) when unset.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_REDIRECT_URI=https://cowork.lk/api/auth/zoho/callback

# Email
RESEND_API_KEY=
EMAIL_FROM=bookings@cowork.lk

# Cron
# Vercel automatically sends this as a Bearer token to /api/cron/* routes when set.
CRON_SECRET=

# Cowork Admin Assist (mobile app)
# Shared Bearer token for the front-desk mobile app's /api/mobile/* routes.
# Company-managed devices, one shared token — not per-agent login.
ADMIN_ASSIST_API_KEY=


#Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
